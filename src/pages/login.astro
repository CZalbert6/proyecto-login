---
import Layout from '../layouts/Layout.astro';
const backendUrl = 'http://localhost:3001'; // Cambia a tu URL de Railway después
---

<Layout>
  <div style="max-width: 400px; margin: 0 auto;">
    <h2 style="text-align: center; margin-bottom: 2rem;">Iniciar Sesión</h2>
    
    <form id="loginForm" style="background: white; padding: 2rem; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Email o Usuario</label>
        <input type="text" id="loginIdentifier" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 5px;" required>
      </div>
      
      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Contraseña</label>
        <input type="password" id="loginPassword" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 5px;" required>
      </div>
      
      <button type="submit" style="width: 100%; padding: 1rem; background: #667eea; color: white; border: none; border-radius: 5px; font-weight: 600; cursor: pointer;">Ingresar</button>
    </form>
    
    <div id="message" style="margin-top: 1rem; padding: 1rem; border-radius: 5px; display: none;"></div>
    
    <p style="text-align: center; margin-top: 1rem;">
      ¿No tienes cuenta? <a href="/register">Regístrate</a>
    </p>
  </div>

  <script>
    const API_URL = '{backendUrl}';

    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const identifier = document.getElementById('loginIdentifier').value.trim();
      const password = document.getElementById('loginPassword').value;
      const messageDiv = document.getElementById('message');
      
      const isEmail = identifier.includes('@');
      const loginData = { password };
      
      if (isEmail) {
        loginData.email = identifier;
      } else {
        loginData.username = identifier;
      }

      messageDiv.style.display = 'none';

      try {
        const response = await fetch(`${API_URL}/api/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(loginData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          localStorage.setItem('token', data.token);
          localStorage.setItem('user', JSON.stringify(data.user));
          messageDiv.style.background = '#d4edda';
          messageDiv.style.color = '#155724';
          messageDiv.textContent = '✅ Login exitoso. Redirigiendo...';
          messageDiv.style.display = 'block';
          setTimeout(() => window.location.href = '/', 1500);
        } else {
          messageDiv.style.background = '#f8d7da';
          messageDiv.style.color = '#721c24';
          messageDiv.textContent = data.message || 'Error en login';
          messageDiv.style.display = 'block';
        }
      } catch (error) {
        messageDiv.style.background = '#f8d7da';
        messageDiv.style.color = '#721c24';
        messageDiv.textContent = 'Error de conexión';
        messageDiv.style.display = 'block';
      }
    });
  </script>
</Layout>