---
import Layout from '../layouts/Layout.astro';
const backendUrl = 'https://proyecto-login-production.up.railway.app';
---

<Layout>
  <div style="max-width: 400px; margin: 0 auto;">
    <h2 style="text-align: center; margin-bottom: 2rem;">Iniciar Sesión</h2>

    <form id="loginForm" style="background: white; padding: 2rem; border-radius: 10px;">
      
      <div style="margin-bottom: 1rem;">
        <label>Email o Usuario</label>
        <input type="text" id="loginIdentifier" required>
      </div>

      <div style="margin-bottom: 1rem;">
        <label>Contraseña</label>
        <input type="password" id="loginPassword" required>
      </div>

      <button type="submit">Ingresar</button>
    </form>

    <div id="message" style="display:none"></div>

  </div>

<script>

const API_URL = "https://proyecto-login-production.up.railway.app";

document.getElementById('loginForm').addEventListener('submit', async (e) => {

e.preventDefault();

const identifier = document.getElementById('loginIdentifier').value.trim();
const password = document.getElementById('loginPassword').value;

const isEmail = identifier.includes("@");

const loginData = { password };

if(isEmail){
loginData.email = identifier;
}else{
loginData.username = identifier;
}

try{

const response = await fetch(`${API_URL}/api/login`,{
method:'POST',
headers:{
'Content-Type':'application/json'
},
body:JSON.stringify(loginData)
});

const data = await response.json();

if(data.success){

localStorage.setItem("token",data.token);
localStorage.setItem("user",JSON.stringify(data.user));

alert("Login correcto");

window.location.href="/";

}else{

alert(data.message);

}

}catch(err){

alert("Error de conexión");

}

});

</script>

</Layout>