---
import Layout from '../layouts/Layout.astro';
const backendUrl = 'https://proyecto-login-production.up.railway.app';
---

<Layout>

<div style="max-width:400px;margin:auto">

<h2>Registro</h2>

<form id="registerForm">

<input type="email" id="email" placeholder="Email">

<input type="text" id="username" placeholder="Usuario">

<input type="text" id="nombre" placeholder="Nombre">

<input type="password" id="password" placeholder="Password" required>

<button type="submit">Registrarse</button>

</form>

</div>

<script>

const API_URL="https://proyecto-login-production.up.railway.app";

document.getElementById("registerForm").addEventListener("submit",async(e)=>{

e.preventDefault();

const email=document.getElementById("email").value.trim();
const username=document.getElementById("username").value.trim();
const nombre=document.getElementById("nombre").value.trim();
const password=document.getElementById("password").value;

const requestData={password};

if(email) requestData.email=email;
if(username) requestData.username=username;
if(nombre) requestData.nombre=nombre;

try{

const response=await fetch(`${API_URL}/api/register`,{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify(requestData)
});

const data=await response.json();

if(data.success){

alert("Registro exitoso");

window.location.href="/login";

}else{

alert(data.message);

}

}catch(error){

alert("Error conexión");

}

});

</script>

</Layout>