---
import Layout from '../layouts/Layout.astro';
const backendUrl = 'http://localhost:3001'; // Cambia a tu URL de Railway después
---

<Layout>
  <div style="max-width: 400px; margin: 0 auto;">
    <h2 style="text-align: center; margin-bottom: 2rem;">Crear Cuenta</h2>
    
    <form id="registerForm" style="background: white; padding: 2rem; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Email</label>
        <input type="email" id="email" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 5px;">
        <small style="color: #666;">O usa nombre de usuario abajo</small>
      </div>
      
      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Nombre de usuario</label>
        <input type="text" id="username" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 5px;">
      </div>
      
      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Nombre completo</label>
        <input type="text" id="nombre" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 5px;">
      </div>
      
      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Contraseña</label>
        <input type="password" id="password" style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 5px;" required>
      </div>
      
      <div style="margin-bottom: 1rem;">
        <div class="h-captcha" data-sitekey="10000000-ffff-ffff-ffff-000000000001"></div>
      </div>
      
      <button type="submit" style="width: 100%; padding: 1rem; background: #48bb78; color: white; border: none; border-radius: 5px; font-weight: 600; cursor: pointer;">Registrarse</button>
    </form>
    
    <div id="message" style="margin-top: 1rem; padding: 1rem; border-radius: 5px; display: none;"></div>
    
    <p style="text-align: center; margin-top: 1rem;">
      ¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
    </p>
  </div>

  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
  <script>
    const API_URL = '{backendUrl}';
    let captchaToken = null;

    window.onCaptchaSuccess = (token) => {
      captchaToken = token;
    };

    document.getElementById('registerForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = document.getElementById('email').value.trim();
      const username = document.getElementById('username').value.trim();
      const nombre = document.getElementById('nombre').value.trim();
      const password = document.getElementById('password').value;
      const messageDiv = document.getElementById('message');
      
      if (!email && !username) {
        showMessage('Debes proporcionar email o nombre de usuario', 'error');
        return;
      }

      if (password.length < 6) {
        showMessage('La contraseña debe tener al menos 6 caracteres', 'error');
        return;
      }

      const requestData = { password, captchaToken: captchaToken || 'test-token' };
      if (email) requestData.email = email;
      if (username) requestData.username = username;
      if (nombre) requestData.nombre = nombre;

      try {
        const response = await fetch(`${API_URL}/api/register`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(requestData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          localStorage.setItem('token', data.token);
          localStorage.setItem('user', JSON.stringify(data.user));
          showMessage('✅ Registro exitoso. Redirigiendo...', 'success');
          setTimeout(() => window.location.href = '/', 1500);
        } else {
          showMessage(data.message || 'Error en registro', 'error');
        }
      } catch (error) {
        showMessage('Error de conexión', 'error');
      }
    });

    function showMessage(text, type) {
      const messageDiv = document.getElementById('message');
      messageDiv.textContent = text;
      messageDiv.style.background = type === 'success' ? '#d4edda' : '#f8d7da';
      messageDiv.style.color = type === 'success' ? '#155724' : '#721c24';
      messageDiv.style.display = 'block';
    }
  </script>
</Layout>